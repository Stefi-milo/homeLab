          "rawSql": "SELECT\n  STR_TO_DATE(DATE_FORMAT(Date, '%Y-%m-01'), '%Y-%m-%d') AS time,\n  MONTHNAME(Date) AS Month,\n\n  SUM(COALESCE(Walk, 0))      AS Walk,\n  SUM(COALESCE(Running, 0))   AS Running,\n  SUM(COALESCE(Gym, 0))       AS Gym,\n  SUM(COALESCE(Swim, 0))      AS Swim,\n  SUM(COALESCE(Karate, 0))    AS Karate,\n  SUM(COALESCE(Squash, 0)) AS Squash,\n  SUM(COALESCE(Badminton, 0)) AS Badminton\n\nFROM sport\nGROUP BY YEAR(Date), MONTH(Date)\n\nUNION ALL\n\nSELECT\n  NULL AS time,\n  'TOTAL' AS Month,\n\n  SUM(COALESCE(Walk, 0))      AS Walk,\n  SUM(COALESCE(Running, 0))   AS Running,\n  SUM(COALESCE(Gym, 0))       AS Gym,\n  SUM(COALESCE(Swim, 0))      AS Swim,\n  SUM(COALESCE(Karate, 0))    AS Karate,\n  SUM(COALESCE(Squash, 0)) AS Squash,\n  SUM(COALESCE(Badminton, 0)) AS Badminton\nFROM sport;\n",
