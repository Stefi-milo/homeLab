          "format": "table",
          "rawQuery": true,
          "rawSql": "SELECT\n    STR_TO_DATE(CONCAT(YEAR(Date), '-', MONTH(Date), '-01'), '%Y-%m-%d') AS time,  -- kept for Grafana\n    DATE_FORMAT(Date, '%M') AS Month,  -- month names\n    SUM(COALESCE(Beer,0)) AS Beer,\n    SUM(COALESCE(Smoke,0)) AS Smoke,\n    SUM(COALESCE(Fun,0)) AS Fun,\n    SUM(COALESCE(Sport,0)) AS Sport\nFROM lifestyle\nWHERE YEAR(Date) = 2026\nGROUP BY YEAR(Date), MONTH(Date)\n\nUNION ALL\n\nSELECT\n    STR_TO_DATE('2026-12-31', '%Y-%m-%d') AS time,  -- total row for the year\n    'TOTAL' AS Month,\n    SUM(COALESCE(Beer,0)) AS Beer,\n    SUM(COALESCE(Smoke,0)) AS Smoke,\n    SUM(COALESCE(Fun,0)) AS Fun,\n    SUM(COALESCE(Sport,0)) AS Sport\nFROM lifestyle\nWHERE YEAR(Date) = 2026\n\nORDER BY time;\n",
